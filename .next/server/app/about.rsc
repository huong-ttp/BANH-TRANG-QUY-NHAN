ter","children":[["$","div",null,{"children":["$","img",null,{"src":"/about.jpg","alt":"Bánh Tráng Quý Nhân","className":"w-full rounded-xl shadow-lg object-cover"}]}],["$","div",null,{"children":[["$","h2",null,{"className":"text-2xl font-bold mb-4","children":"Về Bánh Tráng Quý Nhân"}],["$","p",null,{"className":"text-muted-foreground leading-7","children":"Bánh Tráng Quý Nhân chuyên cung cấp các loại bánh tráng, muối tôm và đặc sản Tây Ninh được tuyển chọn từ những cơ sở sản xuất uy tín."}],["$","p",null,{"className":"text-muted-foreground leading-7 mt-4","children":"Chúng tôi mong muốn đưa những hương vị quen thuộc của vùng đất Tây Ninh đến gần hơn với khách hàng trên khắp cả nước, đồng thời góp phần quảng bá văn hóa ẩm thực địa phương thông qua từng sản phẩm."}],["$","p",null,{"className":"text-muted-foreground leading-7 mt-4","children":"Mỗi sản phẩm đều được lựa chọn kỹ lưỡng nhằm đảm bảo chất lượng, an toàn và giữ được hương vị truyền thống vốn có."}]]}]]}]}]}],["$","div",null,{"ref":"$undefined","className":"rounded-lg border bg-card text-card-foreground shadow-sm","children":[["$","div",null,{"ref":"$undefined","className":"flex flex-col space-y-1.5 p-6","children":[["$","div",null,{"ref":"$undefined","className":"font-semibold tracking-tight text-3xl","children":"Câu Chuyện Của Quý Nhân"}],["$","div",null,{"ref":"$undefined","className":"text-sm text-muted-foreground","children":"Mang hương vị đặc sản Tây Ninh đến gần hơn với mọi người"}]]}],["$","div",null,{"ref":"$undefined","className":"p-6 pt-0 space-y-10","children":[["$","div",null,{"className":"space-y-4","children":[["$","h3",null,{"className":"text-2xl font-bold text-emerald-600","children":"Bánh Tráng Quý Nhân – Mang Hương Vị Tây Ninh Đến Gần Hơn Với Mọi Người"}],["$","p",null,{"className":"text-muted-foreground leading-8","children":"Tây Ninh không chỉ nổi tiếng với Núi Bà Đen, Tòa Thánh Cao Đài hay những cánh đồng trải dài dưới nắng. Nơi đây còn được biết đến là quê hương của những món đặc sản đã trở thành niềm tự hào của người dân địa phương, trong đó có bánh tráng và muối Tây Ninh."}],["$","p",null,{"className":"text-muted-foreground leading-8","children":"Bánh Tráng Quý Nhân được hình thành từ tình yêu dành cho những hương vị quen thuộc của quê hương. Từ những chiếc bánh tráng giản dị gắn liền với bữa ăn gia đình đến những món ăn vặt được yêu thích trên khắp cả nước, mỗi sản phẩm đều mang theo câu chuyện về sự cần cù, sáng tạo và tinh thần gìn giữ giá trị truyền thống của người dân Tây Ninh."}],["$","p",null,{"className":"text-muted-foreground leading-8","children":"Chúng tôi tin rằng đặc sản không chỉ đơn thuần là một món ăn. Đó còn là cách để giới thiệu văn hóa, con người và những nét đẹp của vùng đất nơi sản phẩm được sinh ra. Chính vì vậy, Bánh Tráng Quý Nhân luôn nỗ lực lựa chọn nguyên liệu chất lượng, hoàn thiện quy trình sản xuất và không ngừng cải tiến sản phẩm để mang đến những hương vị đặc trưng nhất của Tây Ninh."}]]}],["$","div",null,{"className":"space-y-4","children":[["$","h3",null,{"className":"text-2xl font-bold","children":"Sứ Mệnh Của Bánh Tráng Quý Nhân"}],["$","p",null,{"className":"text-muted-foreground leading-8","children":"Bánh Tráng Quý Nhân ra đời với mong muốn góp phần lan tỏa giá trị của đặc sản Tây Ninh đến nhiều khách hàng hơn trên khắp cả nước."}],["$","p",null,{"className":"text-muted-foreground leading-8","children":"Mỗi sản phẩm được tạo ra không chỉ nhằm đáp ứng nhu cầu thưởng thức mà còn là cầu nối đưa hình ảnh quê hương Tây Ninh đến gần hơn với cộng đồng. Từ bánh tráng phơi sương truyền thống, bánh tráng ăn vặt đến các dòng muối đặc sản, tất cả đều được phát triển với mục tiêu giữ gìn hương vị đặc trưng vốn có của địa phương."}]]}],["$","div",null,{"className":"space-y-6","children":[["$","h3",null,{"className":"text-2xl font-bold","children":"Giá Trị Mà Chúng Tôi Theo Đuổi"}],["$","div",null,{"className":"grid gap-4 md:grid-cols-3","children":[["$","div",null,{"className":"rounded-xl border p-6","children":[["$",